<Application x:Class="BackupMonitor.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Startup="OnApplicationStartup">
    <Application.Resources>
        <ResourceDictionary>
            <!-- Основные цвета -->
            <SolidColorBrush x:Key="BackgroundColor" Color="#0A0A0A"/>
            <SolidColorBrush x:Key="CardBackground" Color="#111111"/>
            <SolidColorBrush x:Key="AccentColor" Color="#00F0FF"/>
            <SolidColorBrush x:Key="TextPrimary" Color="#FFFFFF"/>
            <SolidColorBrush x:Key="TextSecondary" Color="#B0B0B0"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
<Window x:Class="BackupMonitor.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BackupMonitor — Вход"
        Height="640" Width="480"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        Background="Transparent"
        AllowsTransparency="True">

    <Window.Effect>
        <DropShadowEffect Color="#000000" Direction="270" ShadowDepth="30" BlurRadius="55" Opacity="0.8"/>
    </Window.Effect>

    <Grid>
        <Border Background="#111111" CornerRadius="32" Margin="35">
            <Grid>
                <!-- Кнопки macOS в правом верхнем углу -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="28 28 28 0">
                    <Ellipse Width="13" Height="13" Fill="#FF5F57" Margin="0 0 8 0"/>
                    <Ellipse Width="13" Height="13" Fill="#FFBC2E" Margin="0 0 8 0"/>
                    <Ellipse Width="13" Height="13" Fill="#28C840"/>
                </StackPanel>

                <!-- Основное содержимое -->
                <StackPanel VerticalAlignment="Center" Margin="55 95 55 0">
                    <TextBlock Text="BackupMonitor" 
                               FontSize="39" 
                               FontWeight="SemiBold" 
                               HorizontalAlignment="Center" 
                               Margin="0 0 0 60"
                               Foreground="#FFFFFF"/>

                    <!-- Поля -->
                    <Border Background="#1A1A1A" CornerRadius="16" Margin="0 12" Padding="6">
                        <TextBox x:Name="ServerBox" 
                                 Height="40" 
                                 FontSize="16.5" 
                                 Background="Transparent" 
                                 BorderThickness="0"
                                 Padding="26 0"
                                 Text="127.0.0.1:5432"
                                 Foreground="#FFFFFF"
                                 VerticalContentAlignment="Center"/>
                    </Border>

                    <Border Background="#1A1A1A" CornerRadius="16" Margin="0 12" Padding="6">
                        <TextBox x:Name="UsernameBox" 
                                 Height="40" 
                                 FontSize="16.5" 
                                 Background="Transparent" 
                                 BorderThickness="0"
                                 Padding="26 0"
                                 Text="postgres"
                                 Foreground="#FFFFFF"
                                 VerticalContentAlignment="Center"/>
                    </Border>

                    <Border Background="#1A1A1A" CornerRadius="16" Margin="0 12" Padding="6">
                        <PasswordBox x:Name="PasswordBox" 
                                     Height="40" 
                                     FontSize="16.5" 
                                     Background="Transparent" 
                                     BorderThickness="0"
                                     Padding="26 0"
                                     Foreground="#FFFFFF"
                                     VerticalContentAlignment="Center"/>
                    </Border>

                                      <Button Content="Подключиться" 
                            Height="40" 
                            FontSize="17" 
                            FontWeight="SemiBold"
                            Margin="20 20 20 20"
                            Background="#1F2A44" 
                            Foreground="#FFFFFF"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="LoginButton_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="18"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
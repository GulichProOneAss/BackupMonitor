<Window x:Class="BackupMonitor.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:material="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="BackupMonitor" 
        Height="720" Width="1280"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource MaterialDesignPaper}"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}">

    <Grid>
        <!-- Боковое меню -->
        <Border Width="260" HorizontalAlignment="Left" 
                Background="{DynamicResource MaterialDesignCardBackground}"
                BorderThickness="0 0 1 0" BorderBrush="{DynamicResource MaterialDesignDivider}">

            <StackPanel Margin="20">
                <TextBlock Text="BackupMonitor" 
                           FontSize="28" FontWeight="SemiBold" 
                           Margin="10 30 10 50"
                           Foreground="{DynamicResource MaterialDesignPrimary}"/>

                <Button Content="📊 Мониторинг" 
                        Style="{StaticResource MaterialDesignFlatButton}" 
                        Height="52" Margin="4" HorizontalAlignment="Stretch"/>
                <Button Content="💾 Создать бэкап" 
                        Style="{StaticResource MaterialDesignFlatButton}" 
                        Height="52" Margin="4" HorizontalAlignment="Stretch"/>
                <Button Content="🔄 Восстановление" 
                        Style="{StaticResource MaterialDesignFlatButton}" 
                        Height="52" Margin="4" HorizontalAlignment="Stretch"/>
                <Button Content="⚙️ Настройки" 
                        Style="{StaticResource MaterialDesignFlatButton}" 
                        Height="52" Margin="4" HorizontalAlignment="Stretch"/>
            </StackPanel>
        </Border>

        <!-- Основная область -->
        <Grid Margin="260,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Заголовок -->
            <Border Grid.Row="0" Height="70" Background="{DynamicResource MaterialDesignPrimary}">
                <TextBlock Text="Мониторинг баз 1С" 
                           FontSize="24" FontWeight="Medium"
                           VerticalAlignment="Center" Margin="30 0 0 0"
                           Foreground="White"/>
            </Border>

            <!-- Таблица -->
            <DataGrid Grid.Row="1" Margin="30"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      Background="{DynamicResource MaterialDesignCardBackground}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="База" Binding="{Binding Name}" Width="*"/>
                    <DataGridTextColumn Header="Последний бэкап" Binding="{Binding LastBackup}" Width="200"/>
                    <DataGridTextColumn Header="Размер" Binding="{Binding Size}" Width="120"/>
                    <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="150"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</Window>